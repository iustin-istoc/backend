# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=schimba_parola
PGDATABASE=smartcity

# Autentificare demonstrativa
ADMIN_USER=admin
ADMIN_PASS=schimba_parola_admin

# WAQI
WAQI_API_TOKEN=your_waqi_token
BACKEND_URL=http://localhost:4000
WAQI_POLL_SECONDS=180
ENV_EXTERNAL_TTL_MS=600000

# uRADMonitor - senzori de mediu LIVE (retea globala)
# Acces public de citire fara cont: lasa valorile www/global.
# Sau pune credentialele tale gratuite (dashboard uRADMonitor > tab API).
URADMONITOR_BASE=https://data.uradmonitor.com
URADMONITOR_USER_ID=www
URADMONITOR_USER_HASH=global
URADMONITOR_POLL_MS=300000
URADMONITOR_MAX_AGE_S=10800
# latMin,lngMin,latMax,lngMax (Cluj-Napoca)
URADMONITOR_BBOX=46.7000,23.4500,46.8600,23.7500

# Open Charge Map - cheie gratuita din profilul Open Charge Map > My Apps
OPENCHARGEMAP_API_KEY=your_open_charge_map_key
OCM_POLL_MS=900000
OCM_MAX_RESULTS=500
OCM_BOUNDING_BOX=(46.7000,23.4500),(46.8600,23.7500)


